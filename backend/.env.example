# Entorno: en producción (Railway) usar NODE_ENV=production
NODE_ENV="development"

# PostgreSQL. En local apunta a docker-compose; en Railway usa la URL del servicio Postgres.
DATABASE_URL="postgresql://renacer:renacer@localhost:5433/renacer?schema=public"

# Secreto JWT: genera uno largo y aleatorio (ej: openssl rand -hex 32). Obligatorio en producción.
JWT_SECRET="genera-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Puerto: en local puedes fijarlo; en Railway lo inyecta la plataforma (no lo definas).
PORT=3001

# Origen(es) permitido(s) para CORS y Socket.IO. Separar varios con coma.
# En producción pon la URL del frontend en Vercel, ej: https://renacer-admin.vercel.app
CORS_ORIGIN="http://localhost:5173"

# Contraseñas iniciales para el seed (no usar valores reales en el repo).
SEED_ADMIN_PASSWORD="cambia-esta-contraseña"
SEED_ASSISTANT_PASSWORD="cambia-esta-contraseña"
